{
  "name": "cso-intel-assistant",
  "version": "0.1.0",
  "description": "Personal AI Assistant for Strategic Intelligence (CSO)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env ./src",
    "dev:all": "node scripts/run-all.js",
    "build": "tsdown",
    "start": "node dist/index.js",
    "lint": "biome check ./src",
    "lint:fix": "biome check --write ./src",
    "typecheck": "tsc --noEmit",
    "volt": "volt"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.0",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@voltagent/cli": "^0.1.10",
    "@voltagent/core": "^2.0.0",
    "@voltagent/libsql": "^2.0.0",
    "@voltagent/logger": "^2.0.0",
    "@voltagent/server-hono": "^2.0.0",
    "ai": "^6.0.0",
    "dotenv": "^16.4.7",
    "exa-js": "^2.13.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.5",
    "@types/pdf-parse": "^1.1.5",
    "tsdown": "^0.15.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
