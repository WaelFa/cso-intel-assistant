# Example .env — copy to .env and fill in real values
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_API_KEY="sk-or-v1-REPLACE_ME_WITH_YOUR_OPENROUTER_KEY"
# Exa.ai API key (optional — enables live market/competitor/regulatory intelligence)
EXA_API_KEY=your-exa-key-here

# Model used by the supervisor and all sub-agents.
# Keep this on a non-reasoning model (gpt-4o-mini, gpt-4.1-mini, claude-haiku).
# Reasoning models (gpt-5-mini, o3-mini, deepseek-r1) cause the supervisor
# to loop on tool calls and never reach the executive-communications sub-agent
# that owns generate_strategic_presentation.
MODEL_ID="openai/gpt-4o-mini"

NODE_ENV=development
